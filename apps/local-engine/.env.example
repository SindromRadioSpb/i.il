# ============================================================
# News Hub Local Engine — Environment Configuration
# Copy to .env and fill in secrets. NEVER commit .env to git.
# ============================================================

# --- Database ---
DATABASE_PATH=data/news_hub.db

# --- Scheduler ---
SCHEDULER_INTERVAL_SEC=600       # 10 minutes between cycles
SCHEDULER_JITTER_SEC=60          # ±60s random jitter

# --- Sources ---
SOURCES_REGISTRY_PATH=../../sources/registry.yaml

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SEC=30
OLLAMA_MAX_RETRIES=2

# --- Summary ---
SUMMARY_TARGET_MIN=400
SUMMARY_TARGET_MAX=700
MAX_SUMMARIES_PER_RUN=50

# --- Facebook (secrets — set in .env, not here) ---
FB_POSTING_ENABLED=false
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_MAX_PER_HOUR=8
FB_MAX_PER_DAY=40
FB_MIN_INTERVAL_SEC=180

# --- Facebook Proof Mode (used with: python main.py --proof-fb) ---
# Enables a single-cycle proof run that hard-stops after N posts.
# Set FB_POSTING_ENABLED=true and fill in credentials before running.
FB_PROOF_MODE=false
FB_PROOF_MAX_POSTS_PER_RUN=3
FB_PROOF_REQUIRE_IMAGE=true
FB_PROOF_ONLY_CATEGORY=         # leave empty to post any category

# --- Image Cache ---
IMAGE_CACHE_DIR=data/images
IMAGE_MAX_SIZE_MB=5
IMAGE_FETCH_TIMEOUT_SEC=15

# --- Cloudflare Sync ---
CF_SYNC_ENABLED=false
CF_SYNC_URL=https://iil.sindromradiospb.workers.dev/api/v1/sync/stories
CF_SYNC_TOKEN=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=data/logs/engine.jsonl

# --- Environment ---
SERVICE_ENV=dev

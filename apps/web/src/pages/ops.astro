let lang = localStorage.getItem('ops-lang') || 'ru';

function setLang(l) {
  lang = l;
  localStorage.setItem('ops-lang', l);
  document.getElementById('lang-ru').classList.toggle('active', l === 'ru');
  document.getElementById('lang-en').classList.toggle('active', l === 'en');
  applyTranslations();
}

function t(key) {
  return STRINGS[lang][key] ?? STRINGS['ru'][key] ?? key;
}

function applyTranslations() {
  // Static text nodes
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    const val = t(key);
    if (typeof val === 'string') el.textContent = val;
  });
  // Button labels via data-i18n-label
  document.querySelectorAll('[data-i18n-label]').forEach(el => {
    const key = el.getAttribute('data-i18n-label');
    const val = t(key);
    if (typeof val === 'string') el.textContent = val;
  });
  // Special: delete-all-drafts button includes count
  const delAllBtn = document.getElementById('delete-all-drafts-btn');
  if (delAllBtn) {
    const fn = STRINGS[lang].deleteAllDrafts;
    if (typeof fn === 'function') delAllBtn.textContent = fn(draftTotal);
  }
}

// Apply on load using saved lang
setLang(lang);

// ── Toast ────────────────────────────────────────────────────────────────────
let toastTimer = null;
function toast(msg, type) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = type; // 'ok' | 'err' | 'inf'
  el.style.display = 'block';
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { el.style.display = 'none'; }, 4000);
}

// ── API helper ───────────────────────────────────────────────────────────────
const H = adminToken ? { 'x-admin-token': adminToken } : {};

async function api(method, path) {
  const res = await fetch(`${apiBase}${path}`, { method, headers: H });
  return res.json();
}

// ── Runs: expand errors on click ─────────────────────────────────────────────
document.querySelectorAll('.run-row').forEach(row => {
  row.addEventListener('click', async () => {
    const runId = row.dataset.runId;
    const errRow = document.getElementById(`errors-${runId}`);
    if (!errRow) return;
    if (errRow.classList.contains('open')) { errRow.classList.remove('open'); return; }
    const container = errRow.querySelector('div');
    if (container && container.textContent.trim() === t('loading')) {
      try {
        const json = await api('GET', `/api/v1/admin/errors?run_id=${encodeURIComponent(runId)}`);
        if (json.ok && json.data.errors.length === 0) {
          container.innerHTML = `<span style="color:#3fb950">${t('noErrors')}</span>`;
        } else if (json.ok) {
          container.innerHTML = json.data.errors.map(e =>
            `<div class="error-item">
               <span class="error-phase">[${e.phase}]</span>
               ${e.source_id ? `<span class="error-src"> ${e.source_id}</span>` : ''}
               ${e.story_id ? `<span class="error-src"> story:${e.story_id.slice(0,8)}</span>` : ''}
               — ${e.message ?? '(no message)'}
             </div>`
          ).join('');
        } else {
          container.innerHTML = `<span style="color:#f85149">${t('errLoad')}</span>`;
        }
      } catch {
        container.innerHTML = `<span style="color:#f85149">${t('errLoad')}</span>`;
      }
    }
    errRow.classList.add('open');
  });
});

// ── Purge old runs ────────────────────────────────────────────────────────────
document.getElementById('purge-runs-btn').addEventListener('click', async () => {
  const days = parseInt(document.getElementById('runs-days').value, 10) || 7;
  const fn = STRINGS[lang].confirmPurgeRuns;
  if (!confirm(fn(days))) return;
  try {
    const json = await api('DELETE', `/api/v1/admin/runs/old?days=${days}`);
    if (json.ok) {
      const fn2 = STRINGS[lang].toastPurgedRuns;
      toast(fn2(json.data.deleted, days), 'ok');
    } else {
      toast(t('toastErr')(json.error?.message ?? '?'), 'err');
    }
  } catch { toast(t('toastErr')('network'), 'err'); }
});

// ── Delete all drafts ─────────────────────────────────────────────────────────
document.getElementById('delete-all-drafts-btn').addEventListener('click', async () => {
  const fn = STRINGS[lang].confirmDeleteAllDrafts;
  if (!confirm(fn(draftTotal))) return;
  try {
    const json = await api('DELETE', '/api/v1/admin/drafts');
    if (json.ok) {
      const fn2 = STRINGS[lang].toastDeletedDrafts;
      toast(fn2(json.data.deleted), 'ok');
      setTimeout(() => window.location.reload(), 1200);
    } else {
      toast(t('toastErr')(json.error?.message ?? '?'), 'err');
    }
  } catch { toast(t('toastErr')('network'), 'err'); }
});

// ── Draft Hold / Release ──────────────────────────────────────────────────────
document.querySelectorAll('.draft-action').forEach(btn => {
  btn.addEventListener('click', async () => {
    const storyId = btn.dataset.storyId;
    const action = btn.dataset.action;
    if (!storyId || !action) return;
    btn.disabled = true;
    btn.textContent = '…';
    try {
      const json = await api('POST', `/api/v1/admin/story/${encodeURIComponent(storyId)}/${action}`);
      if (json.ok) {
        window.location.reload();
      } else {
        btn.disabled = false;
        btn.textContent = t(action === 'hold' ? 'hold' : 'release');
        toast(t('toastErr')(json.error?.message ?? '?'), 'err');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = t(action === 'hold' ? 'hold' : 'release');
      toast(t('toastErr')('network'), 'err');
    }
  });
});

// ── Delete story (draft or published) ────────────────────────────────────────
document.querySelectorAll('.story-delete-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const storyId = btn.dataset.storyId;
    const title = btn.dataset.title ?? storyId;
    const fn = STRINGS[lang].confirmDeleteStory;
    if (!confirm(fn(title))) return;
    btn.disabled = true;
    try {
      const json = await api('DELETE', `/api/v1/admin/story/${encodeURIComponent(storyId)}`);
      if (json.ok) {
        toast(t('toastDeletedStory'), 'ok');
        const row = btn.closest('tr');
        if (row) row.style.opacity = '0.3';
        setTimeout(() => window.location.reload(), 1000);
      } else {
        btn.disabled = false;
        toast(t('toastErr')(json.error?.message ?? '?'), 'err');
      }
    } catch {
      btn.disabled = false;
      toast(t('toastErr')('network'), 'err');
    }
  });
});

// ── Hide published story ──────────────────────────────────────────────────────
document.querySelectorAll('.story-hide-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const storyId = btn.dataset.storyId;
    const title = btn.dataset.title ?? storyId;
    const fn = STRINGS[lang].confirmHide;
    if (!confirm(fn(title))) return;
    btn.disabled = true;
    try {
      const json = await api('POST', `/api/v1/admin/story/${encodeURIComponent(storyId)}/hide`);
      if (json.ok) {
        toast(t('toastHidden'), 'ok');
        setTimeout(() => window.location.reload(), 1000);
      } else {
        btn.disabled = false;
        toast(t('toastErr')(json.error?.message ?? '?'), 'err');
      }
    } catch {
      btn.disabled = false;
      toast(t('toastErr')('network'), 'err');
    }
  });
});

// ── Reset FB status ───────────────────────────────────────────────────────────
document.querySelectorAll('.story-fb-reset-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const storyId = btn.dataset.storyId;
    btn.disabled = true;
    try {
      const json = await api('POST', `/api/v1/admin/story/${encodeURIComponent(storyId)}/fb-reset`);
      if (json.ok) {
        toast(t('toastFbReset'), 'inf');
        setTimeout(() => window.location.reload(), 1200);
      } else {
        btn.disabled = false;
        toast(t('toastErr')(json.error?.message ?? '?'), 'err');
      }
    } catch {
      btn.disabled = false;
      toast(t('toastErr')('network'), 'err');
    }
  });
});

// ── Purge old errors ──────────────────────────────────────────────────────────
document.getElementById('purge-errors-btn').addEventListener('click', async () => {
  const days = parseInt(document.getElementById('errors-days').value, 10) || 3;
  const fn = STRINGS[lang].confirmPurgeErrors;
  if (!confirm(fn(days))) return;
  try {
    const json = await api('DELETE', `/api/v1/admin/errors/old?days=${days}`);
    if (json.ok) {
      const fn2 = STRINGS[lang].toastPurgedErrors;
      toast(fn2(json.data.deleted, days), 'ok');
    } else {
      toast(t('toastErr')(json.error?.message ?? '?'), 'err');
    }
  } catch { toast(t('toastErr')('network'), 'err'); }
});

// ── Trigger cron ──────────────────────────────────────────────────────────────
document.getElementById('trigger-cron-btn').addEventListener('click', async () => {
  const fn = STRINGS[lang].confirmTriggerCron;
  if (!confirm(fn())) return;
  const btn = document.getElementById('trigger-cron-btn');
  btn.disabled = true;
  try {
    const json = await api('POST', '/api/v1/admin/cron/trigger');
    if (json.ok) {
      toast(t('toastCronTriggered'), 'inf');
    } else {
      toast(t('toastErr')(json.error?.message ?? '?'), 'err');
    }
  } catch {
    toast(t('toastErr')('network'), 'err');
  } finally {
    setTimeout(() => { btn.disabled = false; }, 5000);
  }
});

// ── Page refresh ──────────────────────────────────────────────────────────────
document.getElementById('refresh-btn').addEventListener('click', () => window.location.reload());
</script>


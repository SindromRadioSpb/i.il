---
const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? 'http://127.0.0.1:8787';
const adminToken = (import.meta.env.PUBLIC_ADMIN_TOKEN as string | undefined) ?? '';
const adminHeaders: Record<string, string> = adminToken ? { 'x-admin-token': adminToken } : {};

interface RunRow {
  run_id: string;
  started_at: string;
  finished_at: string | null;
  status: string;
  sources_ok: number;
  sources_failed: number;
  items_found: number;
  items_new: number;
  stories_new: number;
  stories_updated: number;
  published_web: number;
  published_fb: number;
  errors_total: number;
  duration_ms: number;
}

interface HealthResponse {
  ok: boolean;
  service: { name: string; version: string; env: string; now_utc: string };
  last_run: RunRow | null;
  top_failing_sources: { source_id: string; error_count: number }[];
}

interface RunsResponse { ok: boolean; data: { runs: RunRow[] }; }

interface DraftStoryRow {
  story_id: string;
  start_at: string;
  last_update_at: string;
  editorial_hold: number;
  item_count: number;
  title_sample: string | null;
}

interface DraftCounts { total: number; held: number; pending: number; }
interface DraftsResponse { ok: boolean; data: { drafts: DraftStoryRow[]; counts: DraftCounts }; }

interface PublishedStoryRow {
  story_id: string;
  last_update_at: string;
  title_ru: string | null;
  category: string;
  fb_status: string | null;
  fb_post_id: string | null;
  fb_attempts: number;
}
interface PublishedResponse { ok: boolean; data: { stories: PublishedStoryRow[] }; }

let health: HealthResponse | null = null;
let runs: RunRow[] = [];
let drafts: DraftStoryRow[] = [];
let draftCounts: DraftCounts = { total: 0, held: 0, pending: 0 };
let published: PublishedStoryRow[] = [];

try {
  const [hRes, rRes, dRes, pRes] = await Promise.all([
    fetch(`${apiBase}/api/v1/health`),
    fetch(`${apiBase}/api/v1/admin/runs`, { headers: adminHeaders }),
    fetch(`${apiBase}/api/v1/admin/drafts`, { headers: adminHeaders }),
    fetch(`${apiBase}/api/v1/admin/published`, { headers: adminHeaders }),
  ]);
  if (hRes.ok) health = await hRes.json() as HealthResponse;
  if (rRes.ok) { const r = await rRes.json() as RunsResponse; if (r.ok) runs = r.data.runs; }
  if (dRes.ok) { const d = await dRes.json() as DraftsResponse; if (d.ok) { drafts = d.data.drafts; draftCounts = d.data.counts; } }
  if (pRes.ok) { const p = await pRes.json() as PublishedResponse; if (p.ok) published = p.data.stories; }
} catch {
  // API unreachable — show empty state
}

function fmtDuration(ms: number): string {
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s`;
}
function fmtTime(iso: string): string {
  return new Date(iso).toLocaleString('ru-RU', {
    month: 'short', day: 'numeric',
    hour: '2-digit', minute: '2-digit', second: '2-digit',
  });
}
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Ops — News Hub</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: ui-monospace, 'Cascadia Code', monospace; font-size: 13px;
           background: #0d1117; color: #c9d1d9; margin: 0; padding: 1.5rem; }

    /* ── Header ── */
    .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.5rem; }
    h1 { font-size: 1.1rem; color: #58a6ff; margin: 0; }
    .header-controls { display: flex; gap: 0.5rem; align-items: center; }
    .lang-toggle { display: flex; gap: 2px; background: #161b22; border: 1px solid #30363d; border-radius: 4px; overflow: hidden; }
    .lang-btn { padding: 3px 10px; font-size: 0.72rem; font-weight: 700; cursor: pointer;
                border: none; background: transparent; color: #8b949e; font-family: inherit; }
    .lang-btn.active { background: #1f6feb; color: #fff; }
    .refresh-btn { padding: 3px 10px; font-size: 0.72rem; font-weight: 600; cursor: pointer;
                   border: 1px solid #30363d; border-radius: 4px; background: #161b22;
                   color: #8b949e; font-family: inherit; }
    .refresh-btn:hover { border-color: #58a6ff; color: #58a6ff; }

    /* ── Layout ── */
    h2 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em;
         color: #8b949e; margin: 1.75rem 0 0.5rem; border-bottom: 1px solid #21262d; padding-bottom: 0.3rem; }
    .section-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin: 1.75rem 0 0.5rem; border-bottom: 1px solid #21262d; padding-bottom: 0.3rem; }
    .section-header h2 { margin: 0; border: none; padding: 0; }
    .section-actions { display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; }

    /* ── Cards ── */
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 0.5rem; margin-bottom: 1rem; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 6px; padding: 0.6rem 0.8rem; }
    .card-label { font-size: 0.7rem; color: #8b949e; }
    .card-value { font-size: 1rem; color: #e6edf3; font-weight: 600; }

    /* ── Tables ── */
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: 0.68rem; color: #8b949e; padding: 0.3rem 0.5rem;
         border-bottom: 1px solid #30363d; text-transform: uppercase; letter-spacing: 0.05em; }
    td { padding: 0.35rem 0.5rem; border-bottom: 1px solid #21262d; vertical-align: middle; }
    tr:hover td { background: #161b22; }
    .run-row { cursor: pointer; }
    .num { text-align: right; color: #8b949e; }
    .num-hi { color: #e6edf3; }

    /* ── Badges ── */
    .badge { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 0.68rem; font-weight: 600; }
    .badge-success  { background: #1a4429; color: #3fb950; }
    .badge-partial  { background: #3d2c00; color: #e3b341; }
    .badge-failure  { background: #3d1414; color: #f85149; }
    .badge-hidden   { background: #21262d; color: #8b949e; }
    .badge-pending  { background: #1f3d5c; color: #58a6ff; }
    .badge-disabled { background: #21262d; color: #8b949e; }
    .badge-published { background: #1a4429; color: #3fb950; }
    .badge-failed   { background: #3d1414; color: #f85149; }
    .held-badge { background: #3d2c00; color: #e3b341; padding: 1px 5px; border-radius: 3px; font-size: 0.65rem; font-weight: 600; }

    /* ── Buttons ── */
    .btn { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 0.68rem;
           font-weight: 600; cursor: pointer; border: 1px solid transparent; font-family: inherit;
           transition: opacity 0.1s; white-space: nowrap; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-hold    { background: #3d2c00; color: #e3b341; border-color: #5a4200; }
    .btn-release { background: #1a4429; color: #3fb950; border-color: #2a6040; }
    .btn-danger  { background: #3d1414; color: #f85149; border-color: #5a2020; }
    .btn-action  { background: #1f3d5c; color: #58a6ff; border-color: #2d5980; }
    .btn-neutral { background: #161b22; color: #8b949e; border-color: #30363d; }
    .btn-primary { background: #1f6feb; color: #fff; border-color: #1f6feb; }
    .btn-danger-bulk { background: #5a0000; color: #f85149; border-color: #7d0000; padding: 3px 10px; }

    /* ── Errors expand row ── */
    .errors-row { display: none; }
    .errors-row td { padding: 0.5rem 1rem; background: #0d1117; }
    .errors-row.open { display: table-row; }
    .error-item { padding: 0.25rem 0; border-bottom: 1px solid #21262d; font-size: 0.75rem; }
    .error-item:last-child { border-bottom: none; }
    .error-phase { color: #58a6ff; }
    .error-src { color: #8b949e; }

    /* ── Misc ── */
    .notice { color: #8b949e; font-style: italic; padding: 0.75rem 0; }
    .fail-src { display: inline-flex; gap: 0.5rem; align-items: center;
                background: #3d1414; border-radius: 4px; padding: 2px 8px; margin: 2px; font-size: 0.75rem; }
    .fail-src-count { color: #f85149; font-weight: 700; }
    .story-title { max-width: 340px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #e6edf3; }
    .action-group { display: flex; gap: 3px; flex-wrap: wrap; }
    .days-input { width: 42px; padding: 2px 5px; font-size: 0.7rem; font-family: inherit;
                  background: #0d1117; border: 1px solid #30363d; border-radius: 3px;
                  color: #e6edf3; text-align: center; }

    /* ── Toast ── */
    #toast { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999;
             background: #161b22; border: 1px solid #30363d; border-radius: 6px;
             padding: 0.6rem 1rem; font-size: 0.8rem; min-width: 220px;
             box-shadow: 0 4px 16px rgba(0,0,0,0.5); display: none; }
    #toast.ok  { border-color: #3fb950; color: #3fb950; }
    #toast.err { border-color: #f85149; color: #f85149; }
    #toast.inf { border-color: #58a6ff; color: #58a6ff; }
  </style>
</head>
<body>

<div class="header">
  <h1>⚙ News Hub — Ops</h1>
  <div class="header-controls">
    <button class="refresh-btn" id="refresh-btn" data-i18n="refresh">↺ Обновить</button>
    <div class="lang-toggle">
      <button class="lang-btn active" id="lang-ru" onclick="setLang('ru')">RU</button>
      <button class="lang-btn" id="lang-en" onclick="setLang('en')">EN</button>
    </div>
  </div>
</div>

<!-- Toast notification -->
<div id="toast"></div>

<!-- ── Local Engine Monitor ── -->
<div class="section-header" style="margin-top:0">
  <h2 data-i18n="localEngine">Локальный движок</h2>
  <div class="section-actions">
    <input id="le-url" type="text" value="http://localhost:9090"
      style="width:200px;padding:2px 6px;font-size:0.7rem;font-family:inherit;
             background:#0d1117;border:1px solid #30363d;border-radius:3px;color:#e6edf3" />
    <button class="btn btn-action" id="le-connect-btn" data-i18n="leConnect">Подключить</button>
    <button class="btn btn-neutral" id="le-disconnect-btn" style="display:none" data-i18n="leDisconnect">Отключить</button>
    <button class="btn btn-danger" id="le-delete-drafts-btn" style="display:none" data-i18n="leDeleteDrafts">Удалить черновики</button>
  </div>
</div>

<div id="le-status-bar" style="display:none;margin-bottom:0.5rem">
  <div class="grid" style="margin-bottom:0.4rem" id="le-counters-grid">
    <div class="card"><div class="card-label" data-i18n="leEngineStatus">Движок</div><div class="card-value" id="le-engine-status">—</div></div>
    <div class="card"><div class="card-label" data-i18n="lePhase">Фаза</div><div class="card-value" id="le-phase">—</div></div>
    <div class="card"><div class="card-label" data-i18n="leElapsed">Время цикла</div><div class="card-value" id="le-elapsed">—</div></div>
    <div class="card"><div class="card-label" data-i18n="leItemsNew">Новостей</div><div class="card-value" id="le-items-new">—</div></div>
    <div class="card"><div class="card-label" data-i18n="lePublished">Опубликовано</div><div class="card-value" id="le-published">—</div></div>
    <div class="card"><div class="card-label" data-i18n="leErrors">Ошибок</div><div class="card-value" id="le-errors">—</div></div>
  </div>
  <!-- Phase progress bar -->
  <div style="margin-bottom:0.5rem;font-size:0.72rem;color:#8b949e">
    <span id="le-phase-detail"></span>
  </div>
  <div style="background:#21262d;border-radius:3px;height:4px;overflow:hidden;margin-bottom:0.75rem">
    <div id="le-progress-bar" style="height:100%;background:#58a6ff;width:0%;transition:width 0.3s"></div>
  </div>
</div>

<div id="le-event-log" style="display:none;background:#0d1117;border:1px solid #21262d;border-radius:4px;
     padding:0.5rem;height:220px;overflow-y:auto;font-size:0.72rem;font-family:inherit;margin-bottom:0.5rem">
  <div style="color:#8b949e;font-style:italic" id="le-log-empty" data-i18n="leWaitingEvents">Ожидание событий…</div>
</div>
<p id="le-disconnected-notice" class="notice" data-i18n="leNotConnected">Движок не подключён. Введите адрес API и нажмите "Подключить".</p>

<!-- ── Health ── -->
{health ? (
  <div>
    <h2 data-i18n="health">Состояние сервиса</h2>
    <div class="grid">
      <div class="card">
        <div class="card-label" data-i18n="service">Сервис</div>
        <div class="card-value">{health.service.name} v{health.service.version}</div>
      </div>
      <div class="card">
        <div class="card-label" data-i18n="environment">Окружение</div>
        <div class="card-value">{health.service.env}</div>
      </div>
      <div class="card">
        <div class="card-label" data-i18n="serverTime">Время сервера</div>
        <div class="card-value" style="font-size:0.85rem">{fmtTime(health.service.now_utc)}</div>
      </div>
      {health.last_run && (
        <div class="card">
          <div class="card-label" data-i18n="lastRun">Последний запуск</div>
          <div class="card-value">
            <span class={`badge badge-${health.last_run.status === 'success' ? 'success' : health.last_run.status === 'partial_failure' ? 'partial' : 'failure'}`}>
              {health.last_run.status === 'partial_failure' ? 'partial' : health.last_run.status}
            </span>
            &nbsp;{fmtDuration(health.last_run.duration_ms)}
          </div>
        </div>
      )}
    </div>
    {health.top_failing_sources.length > 0 && (
      <div style="margin-bottom:0.75rem">
        <span style="font-size:0.72rem;color:#8b949e;text-transform:uppercase;letter-spacing:0.05em" data-i18n="failingSources">Проблемные источники (24ч):</span>
        &nbsp;
        {health.top_failing_sources.map(s => (
          <span class="fail-src">{s.source_id} <span class="fail-src-count">{s.error_count}</span></span>
        ))}
      </div>
    )}
  </div>
) : (
  <p class="notice" data-i18n="healthUnreachable">Health API недоступен.</p>
)}

<!-- ── Runs ── -->
<div class="section-header">
  <h2 data-i18n="recentRuns">Последние запуски</h2>
  <div class="section-actions">
    <input class="days-input" id="runs-days" type="number" value="7" min="1" max="365" title="days" />
    <button class="btn btn-danger" id="purge-runs-btn" data-i18n="purgeRuns">Очистить старые</button>
  </div>
</div>

{runs.length === 0 ? (
  <p class="notice" data-i18n="noRuns">Запусков пока нет.</p>
) : (
  <table id="runs-table">
    <thead>
      <tr>
        <th data-i18n="started">Запущен</th>
        <th data-i18n="status">Статус</th>
        <th class="num" data-i18n="dur">Длит.</th>
        <th class="num">Src✓</th>
        <th class="num">Src✗</th>
        <th class="num" data-i18n="items">Новости</th>
        <th class="num" data-i18n="new">Новые</th>
        <th class="num" data-i18n="stories">Сторис</th>
        <th class="num">Web</th>
        <th class="num">FB</th>
        <th class="num" data-i18n="errors">Ошибки</th>
      </tr>
    </thead>
    <tbody>
      {runs.map((r) => (
        <>
          <tr data-run-id={r.run_id} class="run-row">
            <td>{fmtTime(r.started_at)}</td>
            <td>
              <span class={`badge badge-${r.status === 'success' ? 'success' : r.status === 'partial_failure' ? 'partial' : 'failure'}`}>
                {r.status === 'partial_failure' ? 'partial' : r.status}
              </span>
            </td>
            <td class="num">{fmtDuration(r.duration_ms)}</td>
            <td class="num num-hi">{r.sources_ok}</td>
            <td class={`num ${r.sources_failed > 0 ? 'num-hi' : ''}`} style={r.sources_failed > 0 ? 'color:#f85149' : ''}>{r.sources_failed}</td>
            <td class="num">{r.items_found}</td>
            <td class="num num-hi">{r.items_new}</td>
            <td class="num">{r.stories_new}+{r.stories_updated}</td>
            <td class="num num-hi">{r.published_web}</td>
            <td class="num num-hi">{r.published_fb}</td>
            <td class={`num`} style={r.errors_total > 0 ? 'color:#f85149' : ''}>{r.errors_total}</td>
          </tr>
          <tr class="errors-row" id={`errors-${r.run_id}`}>
            <td colspan="11"><div class="errors-loading" data-i18n="loading">Загрузка…</div></td>
          </tr>
        </>
      ))}
    </tbody>
  </table>
)}

<!-- ── Draft stories ── -->
<div class="section-header">
  <h2 data-i18n="draftStories">Черновики</h2>
  <div class="section-actions">
    <button class="btn btn-danger-bulk" id="delete-all-drafts-btn" data-i18n="deleteAllDrafts">🗑 Удалить все черновики ({draftCounts.total})</button>
  </div>
</div>

<div class="grid" style="margin-bottom:0.75rem">
  <div class="card">
    <div class="card-label" data-i18n="totalDrafts">Всего черновиков</div>
    <div class="card-value">{draftCounts.total}</div>
  </div>
  <div class="card">
    <div class="card-label" data-i18n="pending">В очереди</div>
    <div class="card-value" style="color:#3fb950">{draftCounts.pending}</div>
  </div>
  <div class="card">
    <div class="card-label" data-i18n="onHold">На удержании</div>
    <div class="card-value" style={draftCounts.held > 0 ? 'color:#e3b341' : ''}>{draftCounts.held}</div>
  </div>
</div>

{drafts.length === 0 ? (
  <p class="notice" data-i18n="noDrafts">Нет черновиков для проверки.</p>
) : (
  <table id="drafts-table">
    <thead>
      <tr>
        <th data-i18n="updated">Обновлён</th>
        <th data-i18n="titleHe">Заголовок (he)</th>
        <th class="num" data-i18n="itemsCount">Новостей</th>
        <th data-i18n="status">Статус</th>
        <th data-i18n="actions">Действия</th>
      </tr>
    </thead>
    <tbody>
      {drafts.map((d) => (
        <tr data-story-id={d.story_id}>
          <td style="white-space:nowrap">{fmtTime(d.last_update_at)}</td>
          <td class="story-title" title={d.title_sample ?? ''}>{d.title_sample ?? '—'}</td>
          <td class="num">{d.item_count}</td>
          <td>{d.editorial_hold ? <span class="held-badge">HELD</span> : <span style="color:#3fb950;font-size:0.7rem">pending</span>}</td>
          <td>
            <div class="action-group">
              {d.editorial_hold ? (
                <button class="btn btn-release draft-action" data-story-id={d.story_id} data-action="release" data-i18n-label="release">Снять</button>
              ) : (
                <button class="btn btn-hold draft-action" data-story-id={d.story_id} data-action="hold" data-i18n-label="hold">Удержать</button>
              )}
              <button class="btn btn-danger story-delete-btn" data-story-id={d.story_id} data-title={d.title_sample ?? d.story_id} data-i18n-label="delete">Удалить</button>
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
)}

<!-- ── Published stories ── -->
<div class="section-header">
  <h2 data-i18n="publishedStories">Опубликованные</h2>
</div>

{published.length === 0 ? (
  <p class="notice" data-i18n="noPublished">Нет опубликованных историй.</p>
) : (
  <table id="published-table">
    <thead>
      <tr>
        <th data-i18n="updated">Обновлён</th>
        <th data-i18n="titleRu">Заголовок (ru)</th>
        <th data-i18n="category">Категория</th>
        <th>FB</th>
        <th class="num">Попыток</th>
        <th data-i18n="actions">Действия</th>
      </tr>
    </thead>
    <tbody>
      {published.map((s) => (
        <tr data-story-id={s.story_id}>
          <td style="white-space:nowrap">{fmtTime(s.last_update_at)}</td>
          <td class="story-title" title={s.title_ru ?? ''}>{s.title_ru ?? '—'}</td>
          <td><span style="color:#8b949e;font-size:0.7rem">{s.category}</span></td>
          <td>
            <span class={`badge badge-${s.fb_status ?? 'disabled'}`}>{s.fb_status ?? 'n/a'}</span>
          </td>
          <td class="num">{s.fb_attempts}</td>
          <td>
            <div class="action-group">
              <button class="btn btn-action story-fb-reset-btn" data-story-id={s.story_id} data-i18n-label="fbReset">FB Reset</button>
              <button class="btn btn-neutral story-hide-btn" data-story-id={s.story_id} data-title={s.title_ru ?? s.story_id} data-i18n-label="hide">Скрыть</button>
              <button class="btn btn-danger story-delete-btn" data-story-id={s.story_id} data-title={s.title_ru ?? s.story_id} data-i18n-label="delete">Удалить</button>
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
)}

<!-- ── Maintenance ── -->
<div class="section-header">
  <h2 data-i18n="maintenance">Обслуживание</h2>
</div>

<div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;margin-bottom:1rem">
  <div style="display:flex;gap:0.4rem;align-items:center">
    <input class="days-input" id="errors-days" type="number" value="3" min="1" max="365" />

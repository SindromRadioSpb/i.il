// ── Local Engine SSE monitor ──────────────────────────────────────────────────
let leEventSource = null;
let leCycleStart = 0;
let leElapsedTimer = null;
const PHASE_PROGRESS = { ingest: 20, summary: 70, images: 85, fb: 95, sync: 100 };

function leEl(id) { return document.getElementById(id); }

function leLog(html, color) {
  const log = leEl('le-event-log');
  const empty = leEl('le-log-empty');
  if (empty) empty.style.display = 'none';
  const div = document.createElement('div');
  div.style.cssText = `padding:2px 0;border-bottom:1px solid #21262d;color:${color || '#c9d1d9'}`;
  div.innerHTML = html;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;
}

function leSetStatus(engineStatus) {
  const strings = STRINGS[lang];
  const statusMap = strings.leStatus || {};
  const el = leEl('le-engine-status');
  if (!el) return;
  el.textContent = statusMap[engineStatus] || engineStatus;
  el.style.color = engineStatus === 'running' ? '#3fb950' : engineStatus === 'sleeping' ? '#e3b341' : '#8b949e';
}

function leSetPhase(phase) {
  const strings = STRINGS[lang];
  const phaseMap = strings.lePhases || {};
  const el = leEl('le-phase');
  if (!el) return;
  el.textContent = phase ? (phaseMap[phase] || phase) : '—';
  const pct = PHASE_PROGRESS[phase] || 0;
  leEl('le-progress-bar').style.width = pct + '%';
}

function leUpdateCounters(counters) {
  if (!counters) return;
  const setVal = (id, v) => { const el = leEl(id); if (el) el.textContent = v; };
  setVal('le-items-new', counters.items_new ?? '—');
  setVal('le-published', counters.published_web ?? '—');
  const errEl = leEl('le-errors');
  if (errEl) {
    errEl.textContent = counters.errors_total ?? '—';
    errEl.style.color = (counters.errors_total || 0) > 0 ? '#f85149' : '';
  }
}

function leStartElapsedTimer() {
  if (leElapsedTimer) clearInterval(leElapsedTimer);
  leCycleStart = Date.now();
  leElapsedTimer = setInterval(() => {
    const sec = Math.floor((Date.now() - leCycleStart) / 1000);
    const el = leEl('le-elapsed');
    if (el) el.textContent = `${Math.floor(sec/60)}:${String(sec%60).padStart(2,'0')}`;
  }, 1000);
}

function leStopElapsedTimer() {
  if (leElapsedTimer) { clearInterval(leElapsedTimer); leElapsedTimer = null; }
}

function leHandleEvent(ev) {
  const type = ev.type;
  const data = ev.data || {};
  const phase = ev.phase;
  const strings = STRINGS[lang];
  const phaseMap = strings.lePhases || {};

  if (type === 'heartbeat') return; // silent

  if (type === 'cycle_start') {
    leStartElapsedTimer();
    leSetStatus('running');
    leSetPhase(null);
    leEl('le-progress-bar').style.width = '5%';
    leLog(`▶ <b>Цикл запущен</b> — run_id: ${data.run_id || '?'}, источников: ${data.sources_count || '?'}`, '#58a6ff');
  } else if (type === 'cycle_done') {
    leStopElapsedTimer();
    leSetStatus('idle');
    leSetPhase(null);
    leEl('le-progress-bar').style.width = '100%';
    setTimeout(() => { leEl('le-progress-bar').style.width = '0%'; }, 2000);
    const status = data.status || '?';
    const color = status === 'success' ? '#3fb950' : status === 'partial_failure' ? '#e3b341' : '#f85149';
    const elapsed = data.elapsed_ms ? `${(data.elapsed_ms/1000).toFixed(0)}с` : '';
    leLog(`■ <b>Цикл завершён</b> — ${status} ${elapsed}`, color);
    if (data.counters) leUpdateCounters(data.counters);
  } else if (type === 'sleeping') {
    leStopElapsedTimer();
    leSetStatus('sleeping');
    leSetPhase(null);
    leEl('le-elapsed').textContent = '—';
    leLog(`⏸ Пауза ${data.seconds || '?'}с, следующий цикл: ${data.next_cycle_at ? data.next_cycle_at.slice(11,16) + ' UTC' : '?'}`, '#8b949e');
  } else if (type === 'phase_start') {
    leSetPhase(phase);
    leLog(`  → <b>${phaseMap[phase] || phase}</b>`, '#58a6ff');
  } else if (type === 'phase_done') {
    const ms = data.elapsed_ms ? `${(data.elapsed_ms/1000).toFixed(1)}с` : '';
    const err = data.error ? ` ⚠ ${data.error}` : '';
    leLog(`  ✓ ${phaseMap[phase] || phase} ${ms}${err}`, data.error ? '#f85149' : '#8b949e');
  } else if (type === 'source_ok') {
    leLog(`    ✓ ${data.source}: +${data.new || 0} новых`, '#3fb950');
  } else if (type === 'source_fail') {
    leLog(`    ✗ ${data.source}: ${data.error || '?'}`, '#f85149');
  } else if (type === 'source_skip') {
    leLog(`    · ${data.source}: пропущен (${data.reason || ''})`, '#8b949e');
  } else if (type === 'story_processing') {
    leEl('le-phase-detail').textContent = `${phaseMap['summary'] || 'Summary'} ${data.idx}/${data.total}`;
    // Update progress within summary phase (20–70%)
    const pct = 20 + Math.round((data.idx / Math.max(data.total, 1)) * 50);
    leEl('le-progress-bar').style.width = pct + '%';
    leLog(`    ⚙ История ${data.idx}/${data.total} — ${data.story_id || ''}`, '#8b949e');
  } else if (type === 'story_ok') {
    leUpdateCounters({ published_web: (parseInt(leEl('le-published').textContent) || 0) + 1 });
    leLog(`    ✓ ${data.title_ru || data.story_id || ''}`, '#3fb950');
  } else if (type === 'story_fail') {
    leLog(`    ✗ ${data.story_id || ''}: ${data.error || '?'}`, '#f85149');
  } else if (type === 'story_skip') {
    leLog(`    · ${data.story_id || ''}: пропущен (${data.reason || ''})`, '#8b949e');
  } else if (type === 'image_ok') {
    leLog(`    ✓ Изображение: ${data.story_id || ''}`, '#8b949e');
  } else if (type === 'image_fail') {
    leLog(`    ✗ Изображение: ${data.story_id || ''}`, '#f85149');
  } else if (type === 'fb_posted') {
    leLog(`    ✓ FB пост: ${data.story_id || ''} ${data.post_id ? '#'+data.post_id : ''}`, '#3fb950');
  } else if (type === 'fb_fail') {
    leLog(`    ✗ FB ошибка: ${data.story_id || ''} — ${data.error || '?'}`, '#f85149');
  } else if (type === 'fb_rate_limited') {
    leLog(`    ⏱ FB rate limit`, '#e3b341');
  } else if (type === 'sync_done') {
    leLog(`    ↑ Синхронизировано: ${data.pushed || 0} историй`, '#58a6ff');
  } else if (type === 'engine_start') {
    leLog(`● Движок запущен (режим: ${data.mode || '?'})`, '#58a6ff');
  } else if (type === 'engine_stop') {
    leStopElapsedTimer();
    leSetStatus('idle');
    leLog(`● Движок остановлен (${data.reason || '?'})`, '#8b949e');
  } else if (type === 'cycle_starting') {
    leSetStatus('running');
    leLog(`▷ Цикл #${data.cycle || '?'} запускается…`, '#58a6ff');
  }
}

const LE_STORAGE_KEY = 'le_url';

async function leConnect(silent = false) {
  if (leEventSource) { leEventSource.close(); leEventSource = null; }

  const url = (leEl('le-url').value || 'http://localhost:9090').replace(/\/$/, '');

  // Quick health check first
  try {
    const resp = await fetch(`${url}/health`, { signal: AbortSignal.timeout(3000) });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const json = await resp.json();
    if (!json.ok) throw new Error('Engine returned ok:false');
  } catch (err) {
    if (!silent) toast(`Движок недоступен: ${err.message}`, 'err');
    return;
  }

  // Persist URL for auto-reconnect on next page load
  try { localStorage.setItem(LE_STORAGE_KEY, url); } catch { /* ignore */ }

  // Show UI
  leEl('le-connect-btn').style.display = 'none';
  leEl('le-disconnect-btn').style.display = '';
  leEl('le-delete-drafts-btn').style.display = '';
  leEl('le-disconnected-notice').style.display = 'none';
  leEl('le-status-bar').style.display = '';
  leEl('le-event-log').style.display = '';
  leEl('le-log-empty').style.display = '';

  // Fetch initial status
  try {
    const resp = await fetch(`${url}/status`);
    const json = await resp.json();
    if (json.ok && json.state) {
      leSetStatus(json.state.engine_status);
      leSetPhase(json.state.phase);
      leUpdateCounters(json.state.counters);
      if (json.state.engine_status === 'running' && json.state.cycle_elapsed_sec) {
        leCycleStart = Date.now() - json.state.cycle_elapsed_sec * 1000;
        leStartElapsedTimer();
      }
    }
  } catch { /* ignore */ }

  // Open SSE stream
  leEventSource = new EventSource(`${url}/stream`);
  leEventSource.onmessage = (e) => {
    try { leHandleEvent(JSON.parse(e.data)); } catch { /* ignore malformed */ }
  };
  leEventSource.onerror = () => {
    leLog('⚠ SSE соединение прервано', '#e3b341');
    leSetStatus('idle');
  };
  if (!silent) toast('Движок подключён', 'ok');
}

function leDisconnect() {
  if (leEventSource) { leEventSource.close(); leEventSource = null; }
  leStopElapsedTimer();
  try { localStorage.removeItem(LE_STORAGE_KEY); } catch { /* ignore */ }
  leEl('le-connect-btn').style.display = '';
  leEl('le-disconnect-btn').style.display = 'none';
  leEl('le-delete-drafts-btn').style.display = 'none';
  leEl('le-status-bar').style.display = 'none';
  leEl('le-event-log').style.display = 'none';
  leEl('le-disconnected-notice').style.display = '';
}

// Auto-reconnect on page load if URL was previously saved
(function leAutoReconnect() {
  try {
    const saved = localStorage.getItem(LE_STORAGE_KEY);
    if (saved) {
      leEl('le-url').value = saved;
      leConnect(true);  // silent=true: no toast on auto-reconnect attempt
    }
  } catch { /* ignore */ }
})();

async function leDeleteDrafts() {
  const url = (leEl('le-url').value || 'http://localhost:9090').replace(/\/$/, '');
  const S = STRINGS[lang];
  if (!confirm(S.leDeleteDraftsConfirm())) return;
  try {
    const resp = await fetch(`${url}/drafts`, { method: 'DELETE' });
    const json = await resp.json();
    if (json.ok) {
      toast(S.leDeleteDraftsOk(json.deleted), 'ok');
      leLog(`🗑 ${S.leDeleteDraftsOk(json.deleted)}`, '#e3b341');
    } else {
      toast(`Ошибка: ${json.error || '?'}`, 'err');
    }
  } catch (err) {
    toast(`Ошибка: ${err.message}`, 'err');
  }
}

leEl('le-connect-btn').addEventListener('click', leConnect);
leEl('le-disconnect-btn').addEventListener('click', leDisconnect);
leEl('le-delete-drafts-btn').addEventListener('click', leDeleteDrafts);
</script>

